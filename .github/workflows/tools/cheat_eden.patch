 bool StandardVmCallbacks::IsAddressInRange(VAddr in) const {
+    // Early rejection of clearly invalid addresses (below 0x40000000)
+    // Switch address space doesn't use the low 1GB for application memory
+    if (in < 0x40000000ULL) {
+        LOG_ERROR(CheatEngine,
+                  "BLOCKED: Cheat attempting to access invalid low address={:016X}, if this "
+                  "persists, "
+                  "the cheat may be incorrect.",
+                  in);
+        return false;
+    }
+    // Also reject addresses that are clearly too high
+    if (in >= 0x1000000000ULL) {
+        LOG_ERROR(CheatEngine,
+                  "BLOCKED: Cheat attempting to access invalid high address={:016X}, if this "
+                  "persists, "
+                  "the cheat may be incorrect.",
+                  in);
+        return false;
+    }
+    // Also check if regions have valid base addresses (not in low memory)
+    // If all regions have base < 0x40000000, they're not properly initialized
+    bool has_valid_region = metadata.main_nso_extents.base >= 0x40000000ULL ||
+                            metadata.heap_extents.base >= 0x40000000ULL ||
+                            metadata.alias_extents.base >= 0x40000000ULL ||
+                            metadata.aslr_extents.base >= 0x40000000ULL;
+    if (!has_valid_region) {
+        LOG_ERROR(CheatEngine,
+                  "BLOCKED: Cheat attempting to access memory at address={:016X} but no valid memory regions "
+                  "are initialized yet.",
+                  in);
+        return false;
+    }
     if ((in < metadata.main_nso_extents.base ||
          in >= metadata.main_nso_extents.base + metadata.main_nso_extents.size) &&
         (in < metadata.heap_extents.base ||
@@ -122,11 +171,10 @@ bool StandardVmCallbacks::IsAddressInRange(VAddr in) const {
          in >= metadata.alias_extents.base + metadata.alias_extents.size) &&
         (in < metadata.aslr_extents.base ||
          in >= metadata.aslr_extents.base + metadata.aslr_extents.size)) {
-        LOG_DEBUG(CheatEngine,
-                  "Cheat attempting to access memory at invalid address={:016X}, if this "
+        LOG_ERROR(CheatEngine,
+                  "BLOCKED: Cheat attempting to access memory at invalid address={:016X}, if this "
                   "persists, "
-                  "the cheat may be incorrect. However, this may be normal early in execution if "
-                  "the game has not properly set up yet.",
+                  "the cheat may be incorrect.",
                   in);
         return false; ///< Invalid addresses will hard crash
     }
@@ -134,6 +182,15 @@ bool StandardVmCallbacks::IsAddressInRange(VAddr in) const {
     return true;
 }
 
+bool StandardVmCallbacks::IsAddressInCodeRegion(VAddr address) const {
+    // Check if address is in MainNso (main executable) or ASLR (may contain code)
+    // Heap and Alias regions are data-only and don't need cache invalidation
+    return (address >= metadata.main_nso_extents.base &&
+            address < metadata.main_nso_extents.base + metadata.main_nso_extents.size) ||
+           (address >= metadata.aslr_extents.base &&
+            address < metadata.aslr_extents.base + metadata.aslr_extents.size);
+}
